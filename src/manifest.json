{
  "manifest_version": 3,
  "name": "LinkMate",
  "version": "0.3.0",
  "description": "AI-powered LinkedIn assistant: SSI tracker, profile audit, comment drafts via OpenAI.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "64": "icons/icon-64.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "style-src-elem 'self' https://cdnjs.cloudflare.com; font-src 'self' https://cdnjs.cloudflare.com; script-src 'self'; default-src 'self' data:; connect-src 'self' data: https://api.openai.com; worker-src 'self'"
  },
  "action": {
    "default_title": "LinkMate",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["linkedin-content.ts"],
      "css": ["linkedin-styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/sales/ssi*"],
      "js": ["ssi-content.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "tabs", "activeTab", "windows", "alarms", "scripting"],
  "host_permissions": ["https://*.linkedin.com/*"],
  "web_accessible_resources": [
    {
      "resources": ["linkedin-styles.css", "engagement-queue.css"],
      "matches": ["https://*.linkedin.com/*"]
    }
  ]
}
