{
  "name": "linkmate-extension",
  "version": "0.1.0",
  "description": "AI-powered LinkedIn assistant: SSI tracker, profile audit, comment drafts via OpenAI.",
  "private": true,
  "scripts": {
    "dev": "parcel watch src/manifest.json --config @parcel/config-webextension",
    "build": "parcel build src/manifest.json --config @parcel/config-webextension",
    "zip": "npm run build && cd dist && zip -r ../linkmate.zip . && cd ..",
    "clean": "rm -rf dist .parcel-cache linkmate.zip",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false --maxWorkers=2",
    "lint": "eslint \"src/**/*.{ts,js}\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.{ts,js}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,js,css,html,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,css,html,json}\"",
    "type-check": "tsc --noEmit --project tsconfig.json"
  },
  "keywords": [
    "chrome-extension",
    "linkedin",
    "ai",
    "openai",
    "ssi",
    "productivity"
  ],
  "author": "LinkMate",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrviduus/linkmate.git"
  },
  "bugs": {
    "url": "https://github.com/mrviduus/linkmate/issues"
  },
  "homepage": "https://github.com/mrviduus/linkmate#readme",
  "devDependencies": {
    "@parcel/config-webextension": "^2.9.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/chrome": "^0.0.242",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "buffer": "^6.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-jest": "^27.9.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4",
    "jsdom": "^26.1.0",
    "parcel": "^2.9.3",
    "prettier": "^3.2.5",
    "process": "^0.11.10",
    "ts-jest": "^29.4.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  }
}
